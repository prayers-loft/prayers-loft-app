# Template for backend environment variables.
# Copy this to /app/backend/.env and fill in real values.
# DO NOT COMMIT THE REAL .env FILE — it is gitignored.

MONGO_URL="mongodb://localhost:27017"
DB_NAME="prayers_loft"

# Provided by Emergent for Claude / OpenAI / Gemini access via emergentintegrations
EMERGENT_LLM_KEY=""

# Phase 2 auth — generate a fresh 32-byte secret for production
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=""
JWT_ISSUER="prayers-loft"
JWT_AUDIENCE="prayers-loft-mobile"

# Apple Sign-In (off until iOS go-live)
APPLE_SIGN_IN_ENABLED="false"
APPLE_TEST_MODE="false"
APPLE_SERVICES_ID="com.prayersloft.app.service"

# Password-reset email delivery via Resend (blank = no-op, anti-enumeration safe)
RESEND_API_KEY=""
RESEND_FROM="Prayers Loft <onboarding@resend.dev>"
APP_PUBLIC_URL="https://prayersloft.app"
