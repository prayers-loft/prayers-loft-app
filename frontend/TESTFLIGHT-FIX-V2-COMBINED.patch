++    borderRadius: 20,
++    borderWidth: 1,
++    borderColor: "rgba(200,169,107,0.28)",
++    padding: 22,
++  },
++  title: {
++    fontSize: 20,
++    fontWeight: "700",
++    color: "#F5EDD8",
++    marginBottom: 6,
++  },
++  subtitle: {
++    fontSize: 14,
++    color: "rgba(245,237,216,0.78)",
++    marginBottom: 14,
++    lineHeight: 20,
++  },
++  errorBox: {
++    maxHeight: 140,
++    backgroundColor: "rgba(0,0,0,0.28)",
++    borderRadius: 10,
++    paddingHorizontal: 12,
++    marginBottom: 16,
++  },
++  errorText: {
++    color: "rgba(245,237,216,0.7)",
++    fontSize: 12,
++    fontFamily: "monospace",
++  },
++  button: {
++    backgroundColor: "#C8A96B",
++    paddingVertical: 14,
