{
  "expo": {
    "name": "Prayers Loft",
    "slug": "prayers-loft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prayersloft",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prayersloft.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Save your prayer cards to share later",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": []
    },
    "android": {
      "package": "com.prayersloft.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0e1a"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0e1a"
        }
      ],
      "expo-audio",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Save your prayer cards to share later",
          "savePhotosPermission": "Save your prayer cards to share later",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID_AFTER_eas_init"
      }
    },
    "owner": "REPLACE_WITH_YOUR_EXPO_USERNAME"
  }
}
